digraph build_tracker_adapter {
  rankdir=LR;
  node [fontname="Helvetica"];
  edge [fontname="Helvetica"];
  Start [label="Start", shape="Mdiamond"];
  Exit [label="Exit", shape="Msquare"];
  SetupDeps [label="Add dippin dependency", shape="parallelogram", timeout="30s", tool_command="set -eu\ncd /Users/clint/code/2389/dippin/tracker\ngo get github.com/2389-research/dippin-lang@v0.1.0\ngo mod tidy\nprintf 'dependency-added'"];
  PlanAdapter [label="Plan the Adapter", model="claude-opus-4-6", prompt="You are implementing a Dippin IR adapter for Tracker.\n\n## Context\nTracker's pipeline package is at /Users/clint/code/2389/dippin/tracker/pipeline/\nDippin IR types are at github.com/2389-research/dippin-lang/ir\n\n## Tracker's current types (pipeline/graph.go)\n- Graph: Name, Nodes map[string]*Node, Edges []*Edge, Attrs map[string]string, StartNode, ExitNode\n- Node: ID, Shape, Label, Attrs map[string]string, Handler string\n- Edge: From, To, Label, Condition string, Attrs map[string]string\n- shapeHandlerMap maps DOT shapes to handler names\n- AddNode resolves Handler from Shape and handles Mdiamond/Msquare\n\n## Dippin IR types (ir/ir.go, ir/edge.go)\n- Workflow: Name, Goal, Start, Exit, Defaults, Nodes []*Node, Edges []*Edge\n- Node: ID, Kind (NodeKind), Label, Config (NodeConfig interface), Retry, IO\n- NodeConfig implementations: AgentConfig, HumanConfig, ToolConfig, ParallelConfig, FanInConfig, SubgraphConfig\n- Edge: From, To, Label, Condition (*Condition with Raw string + Parsed AST), Weight, Restart\n- WorkflowDefaults: Model, Provider, RetryPolicy, MaxRetries, Fidelity, MaxRestarts, etc.\n\n## What to build\n1. New file: pipeline/dippin_adapter.go\n   - func FromDippinIR(w *ir.Workflow) *Graph\n   - Maps NodeKind back to DOT shapes for handler resolution\n   - Extracts kind-specific config into Attrs map\n   - Maps WorkflowDefaults to graph Attrs\n   - Converts Edge conditions (use Condition.Raw)\n\n2. New file: pipeline/dippin_adapter_test.go\n   - Round-trip test: parse .dip → adapter → validate Graph\n   - Test each node kind maps correctly\n   - Test edge conditions preserved\n   - Test defaults mapped\n\n3. Update: cmd/tracker/main.go\n   - In run() and runTUI(), auto-detect .dip vs .dot by extension\n   - Call dippin parser + adapter for .dip files\n   - Fall through to existing ParseDOT for .dot files\n\nProduce a detailed plan with exact function signatures, field mappings, and test cases.", shape="box"];
  ImplementFanOut [label="ImplementFanOut", shape="component", targets="ImplementClaude,ImplementGPT"];
  ImplementClaude [label="Implement (Claude)", model="claude-opus-4-6", prompt="Implement the Tracker Dippin adapter according to the plan.\n\nCreate these files in /Users/clint/code/2389/dippin/tracker/:\n1. pipeline/dippin_adapter.go - the FromDippinIR function\n2. pipeline/dippin_adapter_test.go - comprehensive tests\n3. Update cmd/tracker/main.go to auto-detect .dip files\n\nKey mappings:\n- ir.NodeAgent → shape \"box\" (handler: codergen)\n- ir.NodeHuman → shape \"hexagon\" (handler: wait.human)\n- ir.NodeTool → shape \"parallelogram\" (handler: tool)\n- ir.NodeParallel → shape \"component\" (handler: parallel)\n- ir.NodeFanIn → shape \"tripleoctagon\" (handler: parallel.fan_in)\n- ir.NodeSubgraph → shape \"tab\" (handler: subgraph)\n- Start node → shape \"Mdiamond\"\n- Exit node → shape \"Msquare\"\n\nAgentConfig fields → Node.Attrs:\n  prompt, system_prompt, llm_model (from cfg.Model), llm_provider,\n  max_turns, goal_gate, auto_status, reasoning_effort, fidelity\n\nHumanConfig fields → Node.Attrs:\n  mode, default (from cfg.Default)\n\nToolConfig fields → Node.Attrs:\n  tool_command (from cfg.Command), timeout\n\nWorkflowDefaults → Graph.Attrs:\n  goal, llm_model, llm_provider, default_retry_policy,\n  default_max_retry, max_restarts\n\nEdge.Condition.Raw → Edge.Condition (strip ctx. prefix for Tracker compatibility)", provider="anthropic", shape="box"];
  ImplementGPT [label="Implement (GPT)", model="gpt-5.4", prompt="Implement the Tracker Dippin adapter according to the plan.\n\nCreate these files in /Users/clint/code/2389/dippin/tracker/:\n1. pipeline/dippin_adapter.go - the FromDippinIR function\n2. pipeline/dippin_adapter_test.go - comprehensive tests\n3. Update cmd/tracker/main.go to auto-detect .dip files\n\nFollow the exact field mappings from the plan.\nEnsure the adapter produces a Graph that is indistinguishable\nfrom one produced by ParseDOT for equivalent workflows.\nUse testdata fixtures for test cases.", provider="openai", shape="box"];
  ImplementJoin [label="ImplementJoin", shape="tripleoctagon", sources="ImplementClaude,ImplementGPT"];
  ValidateBuild [label="Build and Test", shape="parallelogram", timeout="2m", tool_command="set -eu\ncd /Users/clint/code/2389/dippin/tracker\ngo build ./... 2>&1\ngo test ./pipeline/... -v -count=1 2>&1\ngo vet ./... 2>&1\nprintf 'validation-pass'"];
  ReviewAnalysis [label="Review Implementation", model="claude-opus-4-6", prompt="Review the adapter implementation for correctness and completeness.\n\nCheck:\n1. Every ir.NodeKind maps to the correct DOT shape\n2. Every config field is extracted to the right Attrs key\n3. Edge conditions are preserved (Raw string used)\n4. Start/exit nodes get Mdiamond/Msquare shapes\n5. WorkflowDefaults map to the right graph Attrs\n6. Tests cover all node kinds and edge cases\n7. Auto-detection in main.go handles both extensions\n8. No import cycles or build errors\n\nRespond with STATUS: success if the implementation is correct.\nRespond with STATUS: fail if rework is needed, explaining what to fix.", shape="box"];
  CommitWork [label="Commit Changes", model="claude-sonnet-4-6", prompt="Commit the Dippin adapter changes to Tracker.\nUse a conventional commit message like:\nfeat(pipeline): add Dippin IR adapter for .dip file support\n\nInclude all new and modified files. Report the commit hash.", shape="box"];

  Start -> SetupDeps;
  SetupDeps -> PlanAdapter;
  PlanAdapter -> ImplementFanOut;
  ImplementFanOut -> ImplementClaude;
  ImplementFanOut -> ImplementGPT;
  ImplementClaude -> ImplementJoin;
  ImplementGPT -> ImplementJoin;
  ImplementJoin -> ValidateBuild;
  ValidateBuild -> ReviewAnalysis [condition="outcome = success", label="outcome = success"];
  ValidateBuild -> ImplementClaude [condition="outcome = fail", label="outcome = fail", restart="true", style="dashed"];
  ReviewAnalysis -> CommitWork [condition="outcome = success", label="outcome = success"];
  ReviewAnalysis -> ImplementClaude [condition="outcome = fail", label="outcome = fail", restart="true", style="dashed"];
  CommitWork -> Exit;
}
