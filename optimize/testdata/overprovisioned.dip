workflow Overprovisioned
  goal: "Workflow using expensive models for simple tasks"
  start: Summarize
  exit: Done

  defaults
    model: claude-opus-4-6
    provider: anthropic

  agent Summarize
    prompt:
      Summarize the results.

  agent Cleanup
    prompt:
      Clean up the output and commit changes.

  agent Done
    prompt:
      Done.

  edges
    Summarize -> Cleanup
    Cleanup -> Done
