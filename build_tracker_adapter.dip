workflow build_tracker_adapter
  goal: "Add Dippin IR support to Tracker: import github.com/2389-research/dippin-lang, write FromDippinIR adapter in pipeline/, update LoadPipeline to auto-detect .dip files, add tests, validate with existing pipelines."
  start: Start
  exit: Exit

  defaults
    model: claude-opus-4-6
    provider: anthropic
    retry_policy: standard
    max_retries: 3
    fidelity: summary:high

  # ── Phase 0: Setup ──────────────────────────────

  agent Start
    label: "Start"

  agent Exit
    label: "Exit"

  tool SetupDeps
    label: "Add dippin dependency"
    timeout: 30s
    command:
      set -eu
      cd /Users/clint/code/2389/dippin/tracker
      go get github.com/2389-research/dippin-lang@v0.1.0
      go mod tidy
      printf 'dependency-added'

  # ── Phase 1: Plan the adapter ───────────────────

  agent PlanAdapter
    label: "Plan the Adapter"
    model: claude-opus-4-6
    reasoning_effort: high
    reads: tool_stdout
    writes: plan
    prompt:
      You are implementing a Dippin IR adapter for Tracker.

      ## Context
      Tracker's pipeline package is at /Users/clint/code/2389/dippin/tracker/pipeline/
      Dippin IR types are at github.com/2389-research/dippin-lang/ir

      ## Tracker's current types (pipeline/graph.go)
      - Graph: Name, Nodes map[string]*Node, Edges []*Edge, Attrs map[string]string, StartNode, ExitNode
      - Node: ID, Shape, Label, Attrs map[string]string, Handler string
      - Edge: From, To, Label, Condition string, Attrs map[string]string
      - shapeHandlerMap maps DOT shapes to handler names
      - AddNode resolves Handler from Shape and handles Mdiamond/Msquare

      ## Dippin IR types (ir/ir.go, ir/edge.go)
      - Workflow: Name, Goal, Start, Exit, Defaults, Nodes []*Node, Edges []*Edge
      - Node: ID, Kind (NodeKind), Label, Config (NodeConfig interface), Retry, IO
      - NodeConfig implementations: AgentConfig, HumanConfig, ToolConfig, ParallelConfig, FanInConfig, SubgraphConfig
      - Edge: From, To, Label, Condition (*Condition with Raw string + Parsed AST), Weight, Restart
      - WorkflowDefaults: Model, Provider, RetryPolicy, MaxRetries, Fidelity, MaxRestarts, etc.

      ## What to build
      1. New file: pipeline/dippin_adapter.go
         - func FromDippinIR(w *ir.Workflow) *Graph
         - Maps NodeKind back to DOT shapes for handler resolution
         - Extracts kind-specific config into Attrs map
         - Maps WorkflowDefaults to graph Attrs
         - Converts Edge conditions (use Condition.Raw)

      2. New file: pipeline/dippin_adapter_test.go
         - Round-trip test: parse .dip → adapter → validate Graph
         - Test each node kind maps correctly
         - Test edge conditions preserved
         - Test defaults mapped

      3. Update: cmd/tracker/main.go
         - In run() and runTUI(), auto-detect .dip vs .dot by extension
         - Call dippin parser + adapter for .dip files
         - Fall through to existing ParseDOT for .dot files

      Produce a detailed plan with exact function signatures, field mappings, and test cases.

  # ── Phase 2: Implement ─────────────────────────

  parallel ImplementFanOut -> ImplementClaude, ImplementGPT

  agent ImplementClaude
    label: "Implement (Claude)"
    model: claude-opus-4-6
    provider: anthropic
    reasoning_effort: high
    fidelity: summary:high
    reads: plan
    prompt:
      Implement the Tracker Dippin adapter according to the plan.

      Create these files in /Users/clint/code/2389/dippin/tracker/:
      1. pipeline/dippin_adapter.go - the FromDippinIR function
      2. pipeline/dippin_adapter_test.go - comprehensive tests
      3. Update cmd/tracker/main.go to auto-detect .dip files

      Key mappings:
      - ir.NodeAgent → shape "box" (handler: codergen)
      - ir.NodeHuman → shape "hexagon" (handler: wait.human)
      - ir.NodeTool → shape "parallelogram" (handler: tool)
      - ir.NodeParallel → shape "component" (handler: parallel)
      - ir.NodeFanIn → shape "tripleoctagon" (handler: parallel.fan_in)
      - ir.NodeSubgraph → shape "tab" (handler: subgraph)
      - Start node → shape "Mdiamond"
      - Exit node → shape "Msquare"

      AgentConfig fields → Node.Attrs:
        prompt, system_prompt, llm_model (from cfg.Model), llm_provider,
        max_turns, goal_gate, auto_status, reasoning_effort, fidelity

      HumanConfig fields → Node.Attrs:
        mode, default (from cfg.Default)

      ToolConfig fields → Node.Attrs:
        tool_command (from cfg.Command), timeout

      WorkflowDefaults → Graph.Attrs:
        goal, llm_model, llm_provider, default_retry_policy,
        default_max_retry, max_restarts

      Edge.Condition.Raw → Edge.Condition (strip ctx. prefix for Tracker compatibility)

  agent ImplementGPT
    label: "Implement (GPT)"
    model: gpt-5.4
    provider: openai
    reasoning_effort: high
    fidelity: summary:high
    reads: plan
    prompt:
      Implement the Tracker Dippin adapter according to the plan.

      Create these files in /Users/clint/code/2389/dippin/tracker/:
      1. pipeline/dippin_adapter.go - the FromDippinIR function
      2. pipeline/dippin_adapter_test.go - comprehensive tests
      3. Update cmd/tracker/main.go to auto-detect .dip files

      Follow the exact field mappings from the plan.
      Ensure the adapter produces a Graph that is indistinguishable
      from one produced by ParseDOT for equivalent workflows.
      Use testdata fixtures for test cases.

  fan_in ImplementJoin <- ImplementClaude, ImplementGPT

  # ── Phase 3: Validate ──────────────────────────

  tool ValidateBuild
    label: "Build and Test"
    timeout: 120s
    command:
      set -eu
      cd /Users/clint/code/2389/dippin/tracker
      go build ./... 2>&1
      go test ./pipeline/... -v -count=1 2>&1
      go vet ./... 2>&1
      printf 'validation-pass'

  # ── Phase 4: Review ────────────────────────────

  agent ReviewAnalysis
    label: "Review Implementation"
    model: claude-opus-4-6
    reasoning_effort: high
    goal_gate: true
    auto_status: true
    reads: last_response
    prompt:
      Review the adapter implementation for correctness and completeness.

      Check:
      1. Every ir.NodeKind maps to the correct DOT shape
      2. Every config field is extracted to the right Attrs key
      3. Edge conditions are preserved (Raw string used)
      4. Start/exit nodes get Mdiamond/Msquare shapes
      5. WorkflowDefaults map to the right graph Attrs
      6. Tests cover all node kinds and edge cases
      7. Auto-detection in main.go handles both extensions
      8. No import cycles or build errors

      Respond with STATUS: success if the implementation is correct.
      Respond with STATUS: fail if rework is needed, explaining what to fix.

  # ── Phase 5: Commit ────────────────────────────

  agent CommitWork
    label: "Commit Changes"
    model: claude-sonnet-4-6
    reasoning_effort: low
    prompt:
      Commit the Dippin adapter changes to Tracker.
      Use a conventional commit message like:
      feat(pipeline): add Dippin IR adapter for .dip file support

      Include all new and modified files. Report the commit hash.

  # ── Edges ───────────────────────────────────────

  edges
    Start -> SetupDeps
    SetupDeps -> PlanAdapter
    PlanAdapter -> ImplementFanOut
    ImplementFanOut -> ImplementClaude
    ImplementFanOut -> ImplementGPT
    ImplementClaude -> ImplementJoin
    ImplementGPT -> ImplementJoin
    ImplementJoin -> ValidateBuild
    ValidateBuild -> ReviewAnalysis when ctx.outcome = success
    ValidateBuild -> ImplementClaude when ctx.outcome = fail restart: true
    ReviewAnalysis -> CommitWork when ctx.outcome = success
    ReviewAnalysis -> ImplementClaude when ctx.outcome = fail restart: true
    CommitWork -> Exit
