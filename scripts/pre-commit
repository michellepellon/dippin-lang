#!/bin/sh
# Pre-commit hook for dippin-lang.
# Mirrors CI exactly — if it passes here, it passes in CI.
# Install: ln -sf ../../scripts/pre-commit .git/hooks/pre-commit
set -e

echo "=== pre-commit: gen-spec freshness ==="
cp cmd/dippin/generated-spec.md /tmp/spec-before-precommit.md
./scripts/gen-spec.sh
if ! diff -q cmd/dippin/generated-spec.md /tmp/spec-before-precommit.md >/dev/null 2>&1; then
  echo "ERROR: cmd/dippin/generated-spec.md is stale"
  echo "Run ./scripts/gen-spec.sh and stage the result"
  exit 1
fi
rm -f /tmp/spec-before-precommit.md

echo "=== pre-commit: go build ==="
go build ./...

echo "=== pre-commit: go vet ==="
go vet ./...

echo "=== pre-commit: golangci-lint ==="
if command -v golangci-lint >/dev/null 2>&1; then
  golangci-lint run --timeout=10m
else
  echo "WARN: golangci-lint not installed — skipping (install: go install github.com/golangci/golangci-lint/cmd/golangci-lint@latest)"
fi

echo "=== pre-commit: gofmt ==="
unformatted=$(gofmt -l . 2>&1 || true)
if [ -n "$unformatted" ]; then
  echo "ERROR: Files not gofmt'd:"
  echo "$unformatted"
  exit 1
fi

echo "=== pre-commit: go test ==="
go test ./... -short -count=1 -race

echo "=== pre-commit: release checks ==="
go test ./releasecheck/ -count=1 -race

echo "=== pre-commit: cyclomatic complexity ==="
violations=$(gocyclo -over 5 . | grep -v _test.go | grep -v scripts/ || true)
if [ -n "$violations" ]; then
  echo "ERROR: Functions exceed cyclomatic complexity threshold (max 5):"
  echo "$violations"
  exit 1
fi

echo "=== pre-commit: cognitive complexity ==="
violations=$(gocognit -over 7 . | grep -v _test.go | grep -v scripts/ || true)
if [ -n "$violations" ]; then
  echo "ERROR: Functions exceed cognitive complexity threshold (max 7):"
  echo "$violations"
  exit 1
fi

echo "=== pre-commit: validate examples ==="
go build -o /tmp/dippin-precommit ./cmd/dippin/
for f in examples/*.dip; do
  /tmp/dippin-precommit validate "$f" > /dev/null 2>&1 || {
    echo "ERROR: $f failed validation"
    /tmp/dippin-precommit validate "$f" 2>&1
    exit 1
  }
done
rm -f /tmp/dippin-precommit

# Regenerate changelog.html if CHANGELOG.md is staged.
if git diff --cached --name-only | grep -q '^CHANGELOG.md$'; then
  echo "=== pre-commit: regenerate changelog.html ==="
  ./scripts/gen-changelog-html.sh
  git add site/changelog.html
fi

# Sync nav if layout partial or any site HTML changed.
if git diff --cached --name-only | grep -qE '^site/_layout/|^site/.*\.html$'; then
  echo "=== pre-commit: sync nav ==="
  ./scripts/sync-nav.sh
  git add site/*.html site/blog/*.html 2>/dev/null || true
fi

echo "=== pre-commit: all checks passed ==="
