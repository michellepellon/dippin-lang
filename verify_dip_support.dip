workflow verify_dip_support
  goal: "Verify Tracker's Dippin integration works correctly, confirm documentation is complete, and produce a report of suggestions for how the Dippin language should evolve to better serve Tracker."
  start: Start
  exit: Exit

  defaults
    model: claude-opus-4-6
    provider: anthropic
    retry_policy: standard
    max_retries: 3
    fidelity: summary:high

  agent Start
    label: "Start"

  agent Exit
    label: "Exit"

  # ── Phase 1: Verify the adapter exists and builds ───

  tool VerifyBuild
    label: "Verify dippin-lang builds in Tracker"
    timeout: 60s
    command:
      set -eu
      cd /Users/clint/code/2389/dippin/tracker

      # Confirm dippin-lang is a dependency
      if ! grep -q 'dippin-lang' go.mod; then
        printf 'FAIL: dippin-lang not in go.mod'
        exit 1
      fi

      # Confirm adapter file exists
      if ! [ -f pipeline/dippin_adapter.go ]; then
        printf 'FAIL: pipeline/dippin_adapter.go not found'
        exit 1
      fi

      # Build and test
      go build ./... 2>&1
      go test ./pipeline/... -run Dippin -v -count=1 2>&1
      printf 'build-and-test-pass'

  # ── Phase 2: Verify every node kind round-trips ─────

  tool VerifyNodeKinds
    label: "Verify all node kinds convert correctly"
    timeout: 60s
    command:
      set -eu
      cd /Users/clint/code/2389/dippin-lang

      # Parse this very pipeline to JSON and check node kinds are present
      go run ./cmd/dippin parse /Users/clint/code/2389/dippin-lang/verify_dip_support.dip 2>&1 | head -200

      # Validate it
      go run ./cmd/dippin validate /Users/clint/code/2389/dippin-lang/verify_dip_support.dip 2>&1

      # Lint it
      go run ./cmd/dippin lint /Users/clint/code/2389/dippin-lang/verify_dip_support.dip 2>&1

      printf 'node-kinds-verified'

  # ── Phase 3: Verify conditional routing works ───────

  tool VerifyConditions
    label: "Verify condition export format"
    timeout: 30s
    command:
      set -eu
      cd /Users/clint/code/2389/dippin-lang

      # Export this pipeline as DOT and verify conditions are Tracker-compatible
      DOT=$(go run ./cmd/dippin export-dot verify_dip_support.dip 2>&1)

      # Conditions should NOT have ctx. prefix (stripped for Tracker)
      if echo "$DOT" | grep -q 'ctx\.outcome'; then
        printf 'FAIL: DOT export still contains ctx. prefix in conditions'
        exit 1
      fi

      # Conditions should be present
      if ! echo "$DOT" | grep -q 'condition='; then
        printf 'FAIL: DOT export missing condition attributes'
        exit 1
      fi

      printf 'conditions-verified'

  # ── Phase 4: Parallel verification ──────────────────

  parallel VerifyFanOut -> VerifyDocs, VerifyExamples

  agent VerifyDocs
    label: "Verify documentation is complete"
    model: claude-opus-4-6
    reasoning_effort: high
    goal_gate: true
    auto_status: true
    prompt:
      Read the Tracker codebase at /Users/clint/code/2389/dippin/tracker/ and
      the Dippin documentation at /Users/clint/code/2389/dippin-lang/docs/.

      Verify that:
      1. pipeline/dippin_adapter.go exists and has doc comments explaining
         the adapter's purpose, field mappings, and usage
      2. The adapter function is referenced or documented somewhere users
         can find it (README, code comments, or integration docs)
      3. cmd/tracker/main.go supports .dip file extension auto-detection
      4. There is at least one .dip test fixture in pipeline/testdata/
      5. The integration guide at dippin-lang/docs/integration.md accurately
         reflects the actual adapter implementation

      For each item, report PASS or FAIL with a brief explanation.

      If all items pass, respond with STATUS: success
      If any item fails, respond with STATUS: fail and list what's missing.

  agent VerifyExamples
    label: "Verify example pipelines work as .dip"
    model: claude-opus-4-6
    reasoning_effort: high
    auto_status: true
    prompt:
      Read the example DOT pipelines at /Users/clint/code/2389/dippin/tracker/examples/.
      Pick the simplest one (not ask_and_execute.dot which is large).

      Then read the Dippin migration tool output by examining what
      /Users/clint/code/2389/dippin-lang/cmd/dippin does with the migrate command.

      Verify that:
      1. The migrate command can convert a Tracker DOT file to .dip format
      2. The converted .dip file passes validation (dippin validate)
      3. The validate-migration command confirms parity between original and converted

      Run these commands and report results. If all pass, respond with STATUS: success.
      If any fail, respond with STATUS: fail and explain what went wrong.

  fan_in VerifyJoin <- VerifyDocs, VerifyExamples

  # ── Phase 5: Produce the evolution report ───────────

  agent ProduceReport
    label: "Produce Dippin Evolution Report"
    model: claude-opus-4-6
    reasoning_effort: high
    prompt:
      You have just verified Tracker's Dippin integration. Now produce a
      detailed report of suggestions for how the Dippin language should
      evolve to better serve Tracker and similar pipeline engines.

      Read these files thoroughly before writing the report:
      - /Users/clint/code/2389/dippin/tracker/pipeline/engine.go (execution model)
      - /Users/clint/code/2389/dippin/tracker/pipeline/handler.go (handler interface)
      - /Users/clint/code/2389/dippin/tracker/pipeline/stylesheet.go (CSS-like config)
      - /Users/clint/code/2389/dippin/tracker/pipeline/fidelity.go (compaction modes)
      - /Users/clint/code/2389/dippin/tracker/pipeline/retry_policy.go (retry strategies)
      - /Users/clint/code/2389/dippin/tracker/pipeline/condition.go (condition evaluator)
      - /Users/clint/code/2389/dippin/tracker/pipeline/context.go (runtime context)
      - /Users/clint/code/2389/dippin/tracker/pipeline/subgraph.go (composition)
      - /Users/clint/code/2389/dippin/tracker/pipeline/transforms.go (graph transforms)
      - /Users/clint/code/2389/dippin/tracker/pipeline/events.go (execution events)
      - /Users/clint/code/2389/dippin/tracker/pipeline/validate.go (existing validation)
      - /Users/clint/code/2389/dippin/tracker/pipeline/validate_semantic.go (semantic checks)
      - /Users/clint/code/2389/dippin-lang/ir/ir.go (current Dippin IR)
      - /Users/clint/code/2389/dippin-lang/ir/edge.go (current edge/condition model)
      - /Users/clint/code/2389/dippin-lang/DIPPIN_DESIGN_PLAN.md (original design)

      Structure the report as:

      ## 1. What Dippin Gets Right
      Things that work well and should not change.

      ## 2. Gaps Between Dippin IR and Tracker Runtime
      Fields, behaviors, or concepts that Tracker uses but Dippin cannot
      express yet. For each gap, explain what Tracker does, what Dippin
      lacks, and suggest a concrete syntax or IR addition.

      ## 3. Condition Language Alignment
      Tracker's condition evaluator supports &&, ||, not, contains,
      startswith, endswith, in. Compare this to Dippin's condition AST.
      Are there mismatches? Should Dippin adopt Tracker's operator syntax
      for better compatibility?

      ## 4. Stylesheet / Theming
      Tracker has a CSS-like stylesheet system (model_stylesheet) for
      setting per-node LLM config via selectors. Dippin deferred this
      to post-v1. Suggest how Dippin could incorporate this — as a
      separate block, an import, or inline syntax.

      ## 5. Fidelity and Compaction
      Tracker has fidelity modes (full, summary:high, summary:medium, etc.)
      and context compaction. How well does Dippin represent these? What's
      missing?

      ## 6. Event Model
      Tracker emits structured events (node start, node complete, edge
      selected, pipeline failed, etc.). Should Dippin have any awareness
      of the event model, or is this purely a runtime concern?

      ## 7. Validation Convergence
      Tracker has its own validate.go and validate_semantic.go. Dippin
      has DIP001-DIP112. Compare the two and suggest which checks should
      live where, and whether Tracker should delegate validation to Dippin.

      ## 8. Composition Model
      Tracker's subgraph handling vs Dippin's SubgraphConfig. What needs
      to improve for real multi-file workflow composition?

      ## 9. Priority Recommendations
      Rank the top 5 changes by impact and effort. What should be built
      first?

      Write the report to /Users/clint/code/2389/dippin-lang/docs/evolution_report.md

  # ── Phase 6: Human review ───────────────────────────

  human ReviewReport
    label: "Review the evolution report. Approve or request changes."
    mode: choice
    default: "approve"

  agent IncorporateFeedback
    label: "Incorporate Feedback"
    model: claude-opus-4-6
    reasoning_effort: high
    prompt:
      The human reviewed the evolution report and requested changes.
      Read their feedback from context and update the report at
      /Users/clint/code/2389/dippin-lang/docs/evolution_report.md
      accordingly. Preserve the overall structure but address their
      specific concerns.

  # ── Edges ───────────────────────────────────────────

  edges
    Start -> VerifyBuild
    VerifyBuild -> VerifyNodeKinds when ctx.outcome = success
    VerifyBuild -> Exit when ctx.outcome = fail
    VerifyNodeKinds -> VerifyConditions when ctx.outcome = success
    VerifyNodeKinds -> Exit when ctx.outcome = fail
    VerifyConditions -> VerifyFanOut when ctx.outcome = success
    VerifyConditions -> Exit when ctx.outcome = fail
    VerifyFanOut -> VerifyDocs
    VerifyFanOut -> VerifyExamples
    VerifyDocs -> VerifyJoin
    VerifyExamples -> VerifyJoin
    VerifyJoin -> ProduceReport
    ProduceReport -> ReviewReport
    ReviewReport -> Exit label: "approve"
    ReviewReport -> IncorporateFeedback label: "revise"
    IncorporateFeedback -> ReviewReport restart: true
