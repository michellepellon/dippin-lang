workflow SpecLoaderDemo
  goal: "Demonstrate spec:, satisfies:, and verify_acid: for spec-first authoring"
  spec: acai features/example/features.yaml
  start: ImplementAuth
  exit: Done

  defaults
    model: claude-sonnet-4-6
    provider: anthropic

  agent ImplementAuth
    label: "Implement AUTH requirements"
    satisfies: example.AUTH.1, example.AUTH.2, example.AUTH.[3-5]
    prompt:
      Implement every AUTH requirement from the workflow's spec.
      Reference each ACID in a comment near the code that satisfies it.

  tool VerifyAuth
    label: "Verify AUTH ACIDs appear in code"
    command: grep -r example.AUTH src/ tests/
    timeout: 30s
    verify_acid: example.AUTH.[1-5]

  agent ImplementClient
    label: "Implement CLIENT requirements"
    satisfies: example.CLIENT.*
    prompt:
      Implement every CLIENT requirement from the workflow's spec.

  agent Done
    label: Done

  edges
    ImplementAuth -> VerifyAuth
    VerifyAuth -> ImplementClient
    ImplementClient -> Done
