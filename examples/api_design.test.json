{
  "tests": [
    {
      "name": "happy path — interview subgraph, quality gate passes",
      "scenario": {"outcome": "success"},
      "expect": {
        "status": "success",
        "visited": [
          "Start", "DescribeProduct", "Interview",
          "ScanContext", "ExtractRequirements",
          "DesignClaude", "DesignGPT", "DesignGemini",
          "Critique", "Synthesize", "QualityGate", "WriteSpec", "Done"
        ],
        "path_contains": [
          "Start", "DescribeProduct", "Interview",
          "ScanContext", "ExtractRequirements",
          "Critique", "Synthesize", "QualityGate", "WriteSpec", "Done"
        ]
      }
    },
    {
      "name": "all three designers run in parallel",
      "scenario": {"outcome": "success"},
      "expect": {
        "visited": ["DesignClaude", "DesignGPT", "DesignGemini"],
        "path_contains": ["DesignFan", "DesignClaude", "DesignGPT", "DesignGemini", "DesignJoin"]
      }
    },
    {
      "name": "quality gate rejects — synthesizer retries",
      "scenario": {"QualityGate.outcome": "fail"},
      "expect": {
        "visited": ["QualityGate", "Synthesize"],
        "immediately_after": {"QualityGate": "Synthesize"}
      }
    },
    {
      "name": "quality gate passes — writes spec to disk",
      "scenario": {"outcome": "success"},
      "expect": {
        "visited": ["QualityGate", "WriteSpec", "Done"],
        "path_contains": ["QualityGate", "WriteSpec", "Done"]
      }
    },
    {
      "name": "full pipeline order preserved",
      "scenario": {"outcome": "success"},
      "expect": {
        "path_contains": [
          "Start", "DescribeProduct", "Interview",
          "ScanContext", "ExtractRequirements",
          "DesignFan",
          "DesignClaude", "DesignGPT", "DesignGemini",
          "DesignJoin",
          "Critique", "Synthesize", "QualityGate",
          "WriteSpec", "Done"
        ]
      }
    },
    {
      "name": "critique follows design join — not skipped",
      "scenario": {"outcome": "success"},
      "expect": {
        "visited": ["DesignJoin", "Critique", "Synthesize"],
        "path_contains": ["DesignJoin", "Critique", "Synthesize"]
      }
    },
    {
      "name": "interview subgraph precedes scan context",
      "scenario": {"outcome": "success"},
      "expect": {
        "path_contains": ["Interview", "ScanContext", "ExtractRequirements", "DesignFan"]
      }
    },
    {
      "name": "write spec is the only exit path",
      "scenario": {"outcome": "success"},
      "expect": {
        "path_contains": ["WriteSpec", "Done"]
      }
    }
  ]
}
